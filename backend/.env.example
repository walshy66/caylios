# Auth mode: "dev" trusts the X-STS-User header (local only); "clerk" verifies
# Clerk session JWTs on the Authorization header.
STS_AUTH_MODE=dev

# Required when STS_AUTH_MODE=clerk
CLERK_ISSUER=
# Optional comma-separated list of allowed azp origins
CLERK_AUTHORIZED_PARTIES=

# Comma-separated user ids treated as STS platform admins
STS_PLATFORM_ADMINS=platform-admin

# Fernet key for encrypting connector OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In dev, a key file is auto-generated under data/ when this is unset.
STS_ENCRYPTION_KEY=

# Tenancy
STS_BASE_DOMAIN=simplets.com.au
STS_DEV_WORKSPACE=coachcw

# Connector developer app credentials (one STS app per provider).
# Without these, the consent flow and token refresh for that provider are unavailable.
STS_HUBSPOT_CLIENT_ID=
STS_HUBSPOT_CLIENT_SECRET=
STS_GOOGLE_DRIVE_CLIENT_ID=
STS_GOOGLE_DRIVE_CLIENT_SECRET=
STS_PANDADOC_CLIENT_ID=
STS_PANDADOC_CLIENT_SECRET=
STS_XERO_CLIENT_ID=
STS_XERO_CLIENT_SECRET=

# Connector behaviour configuration
STS_GOOGLE_DRIVE_PARENT_FOLDER_ID=
STS_PANDADOC_TEMPLATE_ID=
STS_XERO_SALES_ACCOUNT_CODE=200

# Forked, white-labeled Activepieces instance for the embedded workflow canvas
STS_ACTIVEPIECES_URL=

# AI extraction: "demo" (deterministic local) or "claude" (Claude API)
STS_EXTRACTION_PROVIDER=demo
ANTHROPIC_API_KEY=
STS_EXTRACTION_MODEL=claude-sonnet-4-6
